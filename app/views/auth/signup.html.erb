<div class="min-h-screen bg-gradient-to-br from-blue-50 via-white to-cyan-50 flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full">
    <!-- Логотип -->
    <div class="text-center mb-8">
      <a href="/" class="inline-block text-3xl font-bold text-primary">
        <i class="fas fa-hotel mr-2"></i>booking.ru
      </a>
    </div>
    
    <!-- Форма регистрации -->
    <div class="bg-white rounded-2xl shadow-xl p-8">
      <h2 class="text-3xl font-bold text-center text-gray-800 mb-2">
        Регистрация
      </h2>
      <p class="text-center text-gray-600 mb-8">
        Создайте аккаунт для бронирования отелей
      </p>
      
      <form class="space-y-6" action="/signup" method="POST">
        <%= csrf_meta_tags %>
        
        <!-- ФИО -->
        <div>
          <label for="username" class="block text-sm font-medium text-gray-700 mb-2">
            <i class="fas fa-user mr-1 text-gray-400"></i>ФИО
          </label>
          <input 
            type="text" 
            id="username" 
            name="username" 
            required
            placeholder="Иванов Иван Иванович"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition"
          >
        </div>
        
        <!-- Email -->
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
            <i class="fas fa-envelope mr-1 text-gray-400"></i>Email
          </label>
          <input 
            type="email" 
            id="email" 
            name="email" 
            required
            placeholder="example@mail.ru"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition"
          >
        </div>
        
        <!-- Телефон -->
        <div>
          <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">
            <i class="fas fa-phone mr-1 text-gray-400"></i>Телефон
          </label>
          <input 
            type="tel" 
            id="phone" 
            name="phone" 
            required
            placeholder="+7 (999) 999-99-99"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition"
          >
        </div>
        
        <!-- Пароль -->
        <div>
          <label for="password" class="block text-sm font-medium text-gray-700 mb-2">
            <i class="fas fa-lock mr-1 text-gray-400"></i>Пароль
          </label>
          <input 
            type="password" 
            id="password" 
            name="password" 
            required
            minlength="6"
            placeholder="Минимум 6 символов"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition"
          >
          <p class="mt-1 text-xs text-gray-500">
            Минимум 6 символов
          </p>
        </div>
        
        <!-- Подтверждение пароля -->
        <div>
          <label for="password_confirmation" class="block text-sm font-medium text-gray-700 mb-2">
            <i class="fas fa-lock mr-1 text-gray-400"></i>Подтвердите пароль
          </label>
          <input 
            type="password" 
            id="password_confirmation" 
            name="password_confirmation" 
            required
            placeholder="Повторите пароль"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition"
          >
        </div>
        
        <!-- Кнопка регистрации -->
        <button 
          type="submit" 
          class="w-full bg-primary text-white py-3 rounded-lg font-semibold hover:bg-blue-700 transition shadow-md"
        >
          <i class="fas fa-user-plus mr-2"></i>Зарегистрироваться
        </button>
      </form>

      <!-- Ссылка на вход -->
      <p class="mt-6 text-center text-sm text-gray-600">
        Уже есть аккаунт? 
        <a href="/login" class="font-medium text-primary hover:text-blue-700">
          Войти
        </a>
      </p>
    </div>
    
    <!-- Дополнительная информация -->
    <p class="mt-6 text-center text-xs text-gray-600">
      Регистрируясь, вы получаете доступ к более чем 2 700 000 отелей по всему миру
    </p>
  </div>
</div>
