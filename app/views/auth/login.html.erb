<div class="min-h-screen bg-gradient-to-br from-blue-50 via-white to-cyan-50 flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full">
    <!-- Логотип -->
    <div class="text-center mb-8">
      <a href="/" class="inline-block text-3xl font-bold text-primary">
        <i class="fas fa-hotel mr-2"></i>booking.ru
      </a>
    </div>
    
    <!-- Форма входа -->
    <div class="bg-white rounded-2xl shadow-xl p-8">
      <h2 class="text-3xl font-bold text-center text-gray-800 mb-2">
        С возвращением!
      </h2>
      <p class="text-center text-gray-600 mb-8">
        Войдите в свой аккаунт для продолжения
      </p>
      
      <form class="space-y-6" action="/login" method="POST">
        <%= csrf_meta_tags %>
        
        <!-- Email -->
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
            <i class="fas fa-envelope mr-1 text-gray-400"></i>Email
          </label>
          <input 
            type="email" 
            id="email" 
            name="email" 
            required
            placeholder="example@mail.ru"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition"
          >
        </div>
        
        <!-- Пароль -->
        <div>
          <label for="password" class="block text-sm font-medium text-gray-700 mb-2">
            <i class="fas fa-lock mr-1 text-gray-400"></i>Пароль
          </label>
          <input 
            type="password" 
            id="password" 
            name="password" 
            required
            placeholder="Введите ваш пароль"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition"
          >
        </div>
        
        <!-- Кнопка входа -->
        <button 
          type="submit" 
          class="w-full bg-primary text-white py-3 rounded-lg font-semibold hover:bg-blue-700 transition shadow-md"
        >
          <i class="fas fa-sign-in-alt mr-2"></i>Войти
        </button>
      </form>
      
      <!-- Ссылка на регистрацию -->
      <p class="mt-6 text-center text-sm text-gray-600">
        Еще нет аккаунта? 
        <a href="/signup" class="font-medium text-primary hover:text-blue-700">
          Зарегистрироваться
        </a>
      </p>
    </div>
    
    <!-- Дополнительная информация -->
    <p class="mt-6 text-center text-xs text-gray-600">
      Быстрое бронирование отелей по всему миру с мгновенным подтверждением
    </p>
  </div>
</div>