<div class="max-w-4xl mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold text-gray-900 mb-6">Личный кабинет</h1>

  <div class="mb-6">
    <%= link_to root_path, class: "inline-flex items-center text-gray-600 hover:text-primary font-medium transition" do %>
    <i class="fas fa-arrow-left mr-2"></i>На главную страницу
    <% end %>
  </div>

  <% if params[:edit] == "true" %>
    <!-- Редактирование профиля -->
    <div class="bg-white rounded-xl shadow-md p-6">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-gray-900">Редактирование профиля</h2>
      </div>

      <%= form_with model: @user, url: profile_path, method: :patch, local: true, class: "space-y-6" do |f| %>
        
        <% if @user.errors.any? %>
          <div class="bg-red-50 border-l-4 border-red-500 text-red-700 p-4 rounded">
            <h3 class="font-bold mb-2">Ошибка при сохранении:</h3>
            <ul class="list-disc list-inside">
              <% @user.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <%= f.label :username, "Имя пользователя *", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :username, required: true, 
              class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" %>
        </div>

        <div>
          <%= f.label :email, "Email *", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email, required: true, 
              class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" %>
        </div>

        <div>
          <%= f.label :phone, "Телефон", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :phone, 
              class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" %>
        </div>

        <div class="flex items-center">
          <%= f.check_box :has_visa, class: "h-4 w-4 text-primary focus:ring-primary border-gray-300 rounded" %>
          <%= f.label :has_visa, "Есть действующая виза", class: "ml-2 text-sm text-gray-700" %>
        </div>

        <div class="flex space-x-3 pt-4">
          <%= f.submit "Сохранить изменения", 
              class: "bg-primary text-white px-6 py-2 rounded-lg font-medium hover:bg-blue-700 transition" %>
          <%= link_to "Отмена", profile_path, 
              class: "px-6 py-2 border border-gray-300 rounded-lg font-medium hover:bg-gray-50 transition" %>
        </div>
      <% end %>
    </div>

  <% else %>
    <!-- Просмотр профиля -->
    <div class="bg-white rounded-xl shadow-md p-6 mb-8">
      <div class="flex items-center justify-between mb-6">
        <div class="flex items-center">
          <div class="h-16 w-16 rounded-full bg-gradient-to-br from-primary to-accent flex items-center justify-center text-white text-2xl font-bold">
            <%= @user.username.first.upcase %>
          </div>
          <div class="ml-4">
            <h2 class="text-xl font-bold text-gray-900"><%= @user.username %></h2>
            <p class="text-gray-600"><%= @user.email %></p>
          </div>
        </div>
        <%= link_to "Редактировать профиль", profile_path(edit: true), 
            class: "bg-primary text-white px-4 py-2 rounded-lg font-medium hover:bg-blue-700 transition" %>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-gray-50 rounded-lg p-4">
          <p class="text-sm text-gray-500 mb-1">Телефон</p>
          <p class="font-medium"><%= @user.phone.presence || 'Не указан' %></p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4">
          <p class="text-sm text-gray-500 mb-1">Виза</p>
          <p class="font-medium">
            <% if @user.has_visa %>
              <span class="inline-flex items-center px-2 py-1 rounded-full bg-green-100 text-green-800 text-xs font-medium">
                <i class="fas fa-check mr-1"></i>Есть
              </span>
            <% else %>
              <span class="inline-flex items-center px-2 py-1 rounded-full bg-gray-100 text-gray-800 text-xs font-medium">
                <i class="fas fa-times mr-1"></i>Нет
              </span>
            <% end %>
          </p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4">
          <p class="text-sm text-gray-500 mb-1">Дата регистрации</p>
          <p class="font-medium"><%= l @user.created_at, format: :long %></p>
        </div>
      </div>
    </div>
  <% end %>
</div>