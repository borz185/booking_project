<!-- Шапка -->
<header class="bg-white shadow-sm sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Логотип -->
      <div class="flex-shrink-0 flex items-center">
        <%= link_to root_path, class: "text-2xl font-bold text-primary" do %>
          <i class="fas fa-hotel mr-2"></i>booking.ru
        <% end %>
      </div>
      
      <!-- Меню -->
      <nav class="hidden md:flex space-x-8">
        <%= link_to hotels_path, class: "text-gray-700 hover:text-primary px-3 py-2 text-medium font-medium transition" do %>
          <i class="fas fa-bed mr-1"></i>Отели
        <% end %>
        <% if logged_in? %>
          <%= link_to bookings_path, class: "text-gray-700 hover:text-primary px-3 py-2 text-medium font-medium transition" do %>
            <i class="fas fa-calendar-check mr-1"></i>Бронирования
          <% end %>
        <% end %>
      </nav>
      
      <!-- Кнопки входа/профиль -->
      <div class="flex items-center space-x-4">
        <% if logged_in? %>
          <!-- Пользователь вошел -->
          <div class="relative inline-block group">
            <button class="flex items-center space-x-2 text-gray-700 hover:text-primary font-medium transition">
              <i class="fas fa-user-circle text-xl"></i>
              <span class="hidden md:inline"><%= current_user.username %></span>
              <i class="fas fa-chevron-down text-xs"></i>
            </button>
            
            <div class="absolute right-0 pt-2 invisible opacity-0 transition-all duration-200 ease-in-out group-hover:visible group-hover:opacity-100 hover:visible hover:opacity-100">
              <!-- Выпадающее меню -->
              <div class="w-48 bg-white rounded-lg shadow-lg py-2">
                <%= link_to bookings_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" do %>
                  <i class="fas fa-calendar-check mr-2"></i>Мои бронирования
                <% end %>
                <% if admin? %>
                  <div class="border-t border-gray-200 my-1"></div>
                  <span class="block px-4 py-2 text-sm text-gray-500">
                    <i class="fas fa-shield-alt mr-2"></i>Админ: <%= current_user.role %>
                  </span>
                <% end %>
                <div class="border-t border-gray-200 my-1"></div>
                <%= button_to logout_path, method: :delete, class: "block w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-gray-100", form: { class: "w-full" } do %>
                  <i class="fas fa-sign-out-alt mr-2"></i>Выйти
                <% end %>
              </div>
            </div>
          </div>
        <% else %>
          <!-- Пользователь не вошел -->
          <%= link_to login_path, class: "text-gray-700 hover:text-primary font-medium transition" do %>
            Войти
          <% end %>
          <%= link_to signup_path, class: "bg-primary text-white px-5 py-2 rounded-lg font-medium hover:bg-blue-700 transition shadow-md" do %>
            Регистрация
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</header>

<!-- Основной контент страницы бронирований -->
<main class="bg-gray-50 min-h-screen py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Заголовок страницы -->
    <div class="mb-8">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900">
        <i class="fas fa-calendar-check mr-3 text-primary"></i>
        Мои бронирования
      </h1>
      <p class="text-gray-600 mt-2">
        Управление вашими бронированиями отелей
      </p>
    </div>
    
    <!-- Список бронирований -->
    <div class="space-y-6">
      <% if @bookings.any? %>
        <% @bookings.each do |booking| %>
          <!-- Карточка бронирования -->
          <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition">
            <div class="flex flex-col md:flex-row">
              
              <!-- Левая часть: Информация об отеле -->
              <div class="md:w-1/3 bg-gradient-to-br from-blue-50 to-cyan-50 p-6">
                <h3 class="text-xl font-bold text-gray-900 mb-2">
                  <%= booking.room.hotel.name %>
                </h3>
                <p class="text-gray-600 text-sm mb-3">
                  <i class="fas fa-map-marker-alt mr-1 text-primary"></i>
                  <%= booking.room.hotel.city %>, <%= booking.room.hotel.country %>
                </p>
                
                <!-- Звезды отеля -->
                <div class="flex items-center mb-3">
                  <% booking.room.hotel.stars.times do %>
                    <i class="fas fa-star text-yellow-400 text-sm"></i>
                  <% end %>
                  <% (5 - booking.room.hotel.stars).times do %>
                    <i class="far fa-star text-gray-300 text-sm"></i>
                  <% end %>
                </div>
                
                <p class="text-gray-700 text-sm line-clamp-2">
                  <%= booking.room.hotel.description %>
                </p>
              </div>
              
              <!-- Центральная часть: Информация о номере и датах -->
              <div class="flex-1 p-6">
                
                <!-- Информация о номере -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                  <div>
                    <p class="text-sm text-gray-500 mb-1">
                      <i class="fas fa-door-open mr-1"></i> Номер
                    </p>
                    <p class="font-semibold text-gray-900">
                      <%= booking.room.room_number %> - <%= booking.room.room_type %>
                    </p>
                  </div>
                  
                  <div>
                    <p class="text-sm text-gray-500 mb-1">
                      <i class="fas fa-users mr-1"></i> Гости
                    </p>
                    <p class="font-semibold text-gray-900">
                      <%= booking.guests_count %> 
                      <% case booking.guests_count
                         when 1 %>гость
                         when 2..4 %>гостя
                         else %>гостей
                         <% end %>
                    </p>
                  </div>
                  
                  <div>
                    <p class="text-sm text-gray-500 mb-1">
                      <i class="fas fa-calendar-alt mr-1"></i> Заезд
                    </p>
                    <p class="font-semibold text-gray-900">
                      <%= l booking.check_in_date, format: :long %>
                    </p>
                  </div>
                  
                  <div>
                    <p class="text-sm text-gray-500 mb-1">
                      <i class="fas fa-calendar-check mr-1"></i> Выезд
                    </p>
                    <p class="font-semibold text-gray-900">
                      <%= l booking.check_out_date, format: :long %>
                    </p>
                  </div>
                </div>
                
                <!-- Длительность пребывания -->
                <div class="bg-gray-50 rounded-lg p-3 mb-4">
                  <% nights = (booking.check_out_date - booking.check_in_date).to_i %>
                  <p class="text-sm text-gray-600">
                    <i class="fas fa-clock mr-2 text-primary"></i>
                    Длительность: 
                    <span class="font-semibold text-gray-900">
                      <%= nights %> 
                      <% case nights
                         when 1 %>ночь
                         when 2..4 %>ночи
                         else %>ночей
                         <% end %>
                    </span>
                  </p>
                </div>
                
                <!-- Статус бронирования -->
                <div class="flex items-center justify-between">
                  <div class="flex items-center">
                    <% case booking.status %>
                    <% when 'confirmed' %>
                      <span class="inline-flex items-center px-3 py-1 rounded-full bg-green-100 text-green-800 text-sm font-medium">
                        <i class="fas fa-check-circle mr-1"></i>
                        Подтверждено
                      </span>
                    <% when 'pending' %>
                      <span class="inline-flex items-center px-3 py-1 rounded-full bg-yellow-100 text-yellow-800 text-sm font-medium">
                        <i class="fas fa-clock mr-1"></i>
                        Ожидает подтверждения
                      </span>
                    <% when 'cancelled' %>
                      <span class="inline-flex items-center px-3 py-1 rounded-full bg-red-100 text-red-800 text-sm font-medium">
                        <i class="fas fa-times-circle mr-1"></i>
                        Отменено
                      </span>
                    <% when 'completed' %>
                      <span class="inline-flex items-center px-3 py-1 rounded-full bg-blue-100 text-blue-800 text-sm font-medium">
                        <i class="fas fa-check-double mr-1"></i>
                        Завершено
                      </span>
                    <% end %>
                  </div>
                  
                  <!-- Кнопки действий -->
                  <div class="flex space-x-2">
                    
                    <% if booking.status == 'pending' || booking.status == 'confirmed' %>
                      <%= button_to cancel_booking_path(booking), 
                          method: :post, 
                          class: "px-4 py-2 bg-red-500 text-white rounded-lg text-sm font-medium hover:bg-red-600 transition",
                          data: { confirm: "Вы уверены что хотите отменить бронирование?" } do %>
                        <i class="fas fa-times mr-1"></i>
                        Отменить
                      <% end %>
                    <% end %>
                  </div>
                </div>
                
              </div>
              
              <!-- Правая часть: Стоимость -->
              <div class="md:w-1/4 bg-gradient-to-br from-green-50 to-emerald-50 p-6 flex flex-col justify-between border-l border-gray-200">
                <div>
                  <p class="text-sm text-gray-600 mb-2">
                    <i class="fas fa-tag mr-1"></i> Общая стоимость
                  </p>
                  <p class="text-3xl font-bold text-primary mb-4">
                    <%= number_to_currency(booking.total_price, unit: "₽", separator: ",", delimiter: " ") %>
                  </p>
                  
                  <div class="space-y-2 text-sm">
                    <div class="flex justify-between text-gray-600">
                      <span>За ночь:</span>
                      <span class="font-medium"><%= number_to_currency(booking.room.price_per_night, unit: "₽") %></span>
                    </div>
                    <div class="flex justify-between text-gray-600">
                      <span>Ночей:</span>
                      <span class="font-medium"><%= (booking.check_out_date - booking.check_in_date).to_i %></span>
                    </div>
                  </div>
                </div>
                
                <!-- Информация о платеже -->
                <% if booking.payment %>
                  <div class="mt-4 pt-4 border-t border-gray-200">
                    <p class="text-xs text-gray-500 mb-1">
                      <i class="fas fa-credit-card mr-1"></i> Оплата
                    </p>
                    <p class="text-sm font-medium text-gray-900">
                      <%= booking.payment.payment_status == 'paid' ? 'Оплачено' : 'Не оплачено' %>
                    </p>
                  </div>
                <% end %>
              </div>
              
            </div>
          </div>
        <% end %>
      <% else %>
        <!-- Если бронирований нет -->
        <div class="bg-white rounded-xl shadow-md p-12 text-center">
          <i class="fas fa-calendar-times text-6xl text-gray-300 mb-4"></i>
          <h3 class="text-xl font-bold text-gray-900 mb-2">
            У вас пока нет бронирований
          </h3>
          <p class="text-gray-600 mb-6">
            Начните планировать свое путешествие прямо сейчас!
          </p>
          <%= link_to hotels_path, class: "inline-flex items-center px-6 py-3 bg-primary text-white rounded-lg font-medium hover:bg-blue-700 transition shadow-md" do %>
            <i class="fas fa-search mr-2"></i>
            Найти отели
          <% end %>
        </div>
      <% end %>
    </div>
    
  </div>
</main>

