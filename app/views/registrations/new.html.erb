<div class="min-h-screen bg-gradient-to-br from-blue-50 via-white to-cyan-50 flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full">
    <div class="text-center mb-8">
      <a href="/" class="inline-block text-3xl font-bold text-primary">
        <i class="fas fa-hotel mr-2"></i>booking.ru
      </a>
    </div>
    
    <div class="bg-white rounded-2xl shadow-xl p-8">
      <h2 class="text-3xl font-bold text-center text-gray-800 mb-2">Регистрация</h2>
      <p class="text-center text-gray-600 mb-8">Создайте аккаунт для бронирования отелей</p>
      
      <% if flash[:alert] %>
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6">
          <%= flash[:alert] %>
        </div>
      <% end %>
      
      <% if flash[:notice] %>
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6">
          <%= flash[:notice] %>
        </div>
      <% end %>
      
      <%= form_with model: @user, url: signup_path, local: true, class: "space-y-6" do |f| %>
        <!-- ФИО -->
        <div>
          <%= f.label :username, class: "block text-sm font-medium text-gray-700 mb-2" do %>
            <i class="fas fa-user mr-1 text-gray-400"></i>ФИО
          <% end %>
          <%= f.text_field :username, 
              required: true, 
              autofocus: true, 
              autocomplete: "name",
              placeholder: "Иванов Иван Иванович",
              minlength: 3,
              maxlength: 50,
              pattern: "[a-zA-Zа-яА-Я0-9_\s]+",
              class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition" %>
          <% if @user.errors[:username].any? %>
            <p class="mt-1 text-sm text-red-600"><%= @user.errors[:username].first %></p>
          <% end %>
          <p class="mt-1 text-xs text-gray-500">3-50 символов, только буквы и цифры</p>
        </div>
        
        <!-- Email -->
        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-2" do %>
            <i class="fas fa-envelope mr-1 text-gray-400"></i>Email
          <% end %>
          <%= f.email_field :email, 
              required: true, 
              autocomplete: "email",
              placeholder: "example@mail.ru",
              maxlength: 255,
              class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition" %>
          <% if @user.errors[:email].any? %>
            <p class="mt-1 text-sm text-red-600"><%= @user.errors[:email].first %></p>
          <% end %>
          <p class="mt-1 text-xs text-gray-500">Пример: user@example.com</p>
        </div>
        
        <!-- Телефон -->
        <div>
          <%= f.label :phone, class: "block text-sm font-medium text-gray-700 mb-2" do %>
            <i class="fas fa-phone mr-1 text-gray-400"></i>Телефон
          <% end %>
          <%= f.telephone_field :phone, 
              autocomplete: "tel",
              placeholder: "+7 (999) 999-99-99",
              pattern: "\+?[0-9\-\(\) ]+",
              class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition" %>
          <% if @user.errors[:phone].any? %>
            <p class="mt-1 text-sm text-red-600"><%= @user.errors[:phone].first %></p>
          <% end %>
          <p class="mt-1 text-xs text-gray-500">Необязательно. Формат: +7 (999) 999-99-99</p>
        </div>
        
        <!-- Пароль -->
        <div>
          <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-2" do %>
            <i class="fas fa-lock mr-1 text-gray-400"></i>Пароль
          <% end %>
          <%= f.password_field :password, 
              required: true, 
              autocomplete: "new-password",
              placeholder: "Минимум 6 символов",
              minlength: 6,
              class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition" %>
          <% if @user.errors[:password].any? %>
            <p class="mt-1 text-sm text-red-600"><%= @user.errors[:password].first %></p>
          <% end %>
          <p class="mt-1 text-xs text-gray-500">Минимум 6 символов</p>
        </div>
        
        <!-- Подтверждение пароля -->
        <div>
          <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-700 mb-2" do %>
            <i class="fas fa-lock mr-1 text-gray-400"></i>Подтвердите пароль
          <% end %>
          <%= f.password_field :password_confirmation, 
              required: true, 
              autocomplete: "new-password",
              placeholder: "Повторите пароль",
              minlength: 6,
              class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition" %>
          <p class="mt-1 text-xs text-gray-500">Повторите пароль для подтверждения</p>
        </div>
        
        <!-- Кнопка регистрации -->
        <%= f.submit "Зарегистрироваться", 
            class: "w-full bg-primary text-white py-3 rounded-lg font-semibold hover:bg-blue-700 transition shadow-md cursor-pointer" %>
      <% end %>
      
      <p class="mt-6 text-center text-sm text-gray-600">
        Уже есть аккаунт? 
        <%= link_to "Войти", login_path, class: "font-medium text-primary hover:text-blue-700" %>
      </p>
    </div>
  </div>
</div>