<!-- JavaScript для подгрузки отелей -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  const loadMoreBtn = document.getElementById('loadMoreBtn');
  const hotelsContainer = document.getElementById('hotelsContainer');
  const loadMoreContainer = document.getElementById('loadMoreContainer');
  
  if (!loadMoreBtn) return;
  
  // Получаем текущие параметры URL для сохранения фильтров
  function getSearchParams() {
    const urlParams = new URLSearchParams(window.location.search);
    return urlParams.toString();
  }
  
  loadMoreBtn.addEventListener('click', async function() {
    const nextPage = this.dataset.nextPage;
    const totalPages = this.dataset.totalPages;
    const searchParams = getSearchParams();
    
    // Показываем состояние загрузки
    this.disabled = true;
    this.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Загрузка...';
    
    try {
      const response = await fetch(`/hotels.json?page=${nextPage}${searchParams ? '&' + searchParams : ''}`);
      
      if (!response.ok) {
        throw new Error('Ошибка загрузки');
      }
      
      const data = await response.json();
      
      if (data.hotels && data.hotels.length > 0) {
        // Добавляем новые карточки
        data.hotels.forEach(hotel => {
          const cardHTML = createHotelCard(hotel);
          hotelsContainer.insertAdjacentHTML('beforeend', cardHTML);
        });
        
        // Обновляем счётчик страниц
        this.dataset.nextPage = data.next_page;
        
        if (data.has_next) {
          // Возвращаем кнопку в исходное состояние
          this.disabled = false;
          this.innerHTML = '<i class="fas fa-plus mr-2"></i>Показать еще';
          // Обновляем текст страницы
          const pageText = this.nextElementSibling;
          if (pageText) {
            pageText.textContent = `Страница ${data.current_page} из ${data.total_pages}`;
          }
        } else {
          // Больше нет страниц - скрываем кнопку
          loadMoreContainer.innerHTML = `
            <div class="bg-green-50 border border-green-200 rounded-lg p-4">
              <p class="text-green-800 text-sm font-medium">
                <i class="fas fa-check-circle mr-1"></i>
                Все отели загружены
              </p>
            </div>
          `;
        }
      }
    } catch (error) {
      console.error('Ошибка загрузки:', error);
      this.disabled = false;
      this.innerHTML = '<i class="fas fa-exclamation-triangle mr-2"></i>Ошибка загрузки. Попробовать снова';
    }
  });
  
  // Функция создания HTML карточки отеля
  function createHotelCard(hotel) {
    const starsHTML = Array(hotel.stars).fill('<i class="fas fa-star text-yellow-400"></i>').join('') + 
                      Array(5 - hotel.stars).fill('<i class="far fa-star text-gray-300"></i>').join('');
    
    const photoHTML = hotel.has_main_photo 
      ? `<img src="${hotel.main_photo_url}" class="w-full h-48 md:h-full object-cover" alt="${hotel.name}">`
      : `<div class="h-48 md:h-full bg-gradient-to-br from-gray-200 to-gray-300 flex items-center justify-center">
           <div class="text-center p-4">
             <i class="fas fa-image text-4xl text-gray-400 mb-2"></i>
             <p class="text-sm text-gray-500">Фото отеля</p>
           </div>
         </div>`;
    
    const visaHTML = hotel.visa_required 
      ? `<div class="inline-flex items-center px-3 py-1 rounded-full bg-orange-100 text-orange-800 text-sm font-medium mb-4">
           <i class="fas fa-passport mr-1"></i>Требуется виза
         </div>` 
      : '';
    
    return `
      <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition hotel-card" data-hotel-id="${hotel.id}">
        <div class="flex flex-col md:flex-row">
          <div class="md:w-1/3 lg:w-1/4">
            ${photoHTML}
          </div>
          <div class="flex-1 p-6">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between mb-3">
              <div>
                <h3 class="text-xl md:text-2xl font-bold text-gray-900">${hotel.name}</h3>
                <p class="text-gray-600 mt-1">
                  <i class="fas fa-map-marker-alt mr-1 text-primary"></i>
                  ${hotel.city}, ${hotel.country}
                </p>
              </div>
              <div class="mt-2 sm:mt-0 flex items-center">
                ${starsHTML}
                <span class="ml-2 text-sm text-gray-500">(${hotel.stars})</span>
              </div>
            </div>
            <p class="text-gray-700 mb-4 line-clamp-2">${hotel.description}</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mb-4 text-sm">
              <p class="text-gray-600">
                <i class="fas fa-home mr-2 text-gray-400"></i>
                ${hotel.address}
              </p>
              <p class="text-gray-600">
                <i class="fas fa-phone mr-2 text-gray-400"></i>
                ${hotel.phone}
              </p>
            </div>
            ${visaHTML}
            <div class="flex items-center justify-between pt-4 border-t border-gray-200">
              <span class="text-sm text-gray-500">
                <i class="fas fa-bed mr-1"></i>
                ${hotel.available_rooms_count} номеров доступно
              </span>
              <a href="/hotels/${hotel.id}/rooms?${getSearchParams()}" 
                 class="bg-primary text-white px-5 py-2 rounded-lg font-medium hover:bg-blue-700 transition shadow-md inline-flex items-center">
                <i class="fas fa-door-open mr-2"></i>
                Показать все номера
              </a>
            </div>
          </div>
        </div>
      </div>
    `;
  }
});
</script>

