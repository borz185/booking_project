<!-- Шапка -->
<header class="bg-white shadow-sm sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Логотип -->
      <div class="flex-shrink-0 flex items-center">
        <%= link_to root_path, class: "text-2xl font-bold text-primary" do %>
          <i class="fas fa-hotel mr-2"></i>booking.ru
        <% end %>
      </div>
      
      <!-- Меню -->
      <nav class="hidden md:flex space-x-8">
        <%= link_to hotels_path, class: "text-gray-700 hover:text-primary px-3 py-2 text-medium font-medium transition" do %>
          <i class="fas fa-bed mr-1"></i>Отели
        <% end %>
        <% if logged_in? %>
          <%= link_to bookings_path, class: "text-gray-700 hover:text-primary px-3 py-2 text-medium font-medium transition" do %>
            <i class="fas fa-calendar-check mr-1"></i>Бронирования
          <% end %>
        <% end %>
      </nav>
      
      <!-- Кнопки входа/профиль -->
      <div class="flex items-center space-x-4">
        <% if logged_in? %>
          <!-- Пользователь вошел -->
          <div class="relative inline-block group">
            <button class="flex items-center space-x-2 text-gray-700 hover:text-primary font-medium transition">
              <i class="fas fa-user-circle text-xl"></i>
              <span class="hidden md:inline"><%= current_user.username %></span>
              <i class="fas fa-chevron-down text-xs"></i>
            </button>
            
            <div class="absolute right-0 pt-2 invisible opacity-0 transition-all duration-200 ease-in-out group-hover:visible group-hover:opacity-100 hover:visible hover:opacity-100">
              <!-- Выпадающее меню -->
              <div class="w-48 bg-white rounded-lg shadow-lg py-2">
                <%= link_to bookings_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" do %>
                  <i class="fas fa-calendar-check mr-2"></i>Мои бронирования
                <% end %>
                <% if admin? %>
                  <div class="border-t border-gray-200 my-1"></div>
                  <span class="block px-4 py-2 text-sm text-gray-500">
                    <i class="fas fa-shield-alt mr-2"></i>Админ: <%= current_user.role %>
                  </span>
                <% end %>
                <div class="border-t border-gray-200 my-1"></div>
                <%= button_to logout_path, method: :delete, class: "block w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-gray-100", form: { class: "w-full" } do %>
                  <i class="fas fa-sign-out-alt mr-2"></i>Выйти
                <% end %>
              </div>
            </div>
          </div>
        <% else %>
          <!-- Пользователь не вошел -->
          <%= link_to login_path, class: "text-gray-700 hover:text-primary font-medium transition" do %>
            Войти
          <% end %>
          <%= link_to signup_path, class: "bg-primary text-white px-5 py-2 rounded-lg font-medium hover:bg-blue-700 transition shadow-md" do %>
            Регистрация
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</header>

<!-- Основной блок -->
<section class="bg-gradient-to-br from-green-400 via-green-300 to-cyan-300 py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-8">
      <h1 class="text-5xl md:text-6xl font-extrabold text-primary mb-4">
        Ооооочень много отелей!
      </h1>
    </div>
    
    <div class="flex flex-col md:flex-row items-center justify-between gap-8">
      <div class="flex-1">
        <p class="text-3xl md:text-4xl font-bold text-primary mb-8">
          Забронировать отпуск поможет booking!
        </p>
        <p class="text-lg md:text-xl text-gray-700 mb-8 max-w-2xl leading-relaxed">
          Более 2 700 000 отелей по всему миру. Лучшие цены, мгновенное подтверждение 
          и круглосуточная поддержка. Найдите идеальный отель за несколько минут!
        </p>
        <button class="bg-primary text-white text-xl font-bold px-10 py-4 rounded-full hover:bg-blue-700 transition shadow-xl transform hover:scale-105">
          <i class="fas fa-search mr-2"></i>ОТЕЛИ
        </button>
      </div>
      
      <div class="flex-1 flex justify-center">
        <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?w=500&h=400&fit=crop" 
             alt="Hotel" 
             class="rounded-2xl shadow-2xl transform rotate-3 hover:rotate-0 transition duration-300">
      </div>
    </div>
  </div>
</section>

<!-- Блок подписки -->
<section class="bg-gray-100 py-16">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
      <div class="flex flex-col md:flex-row">
        <div class="md:w-1/3">
          <img src="https://images.unsplash.com/photo-1437719417032-8595fd9e9dc6?w=400&h=400&fit=crop" 
               alt="Island" 
               class="w-full h-full object-cover">
        </div>
        <div class="md:w-2/3 p-8 md:p-12">
          <h2 class="text-3xl font-bold text-gray-800 mb-3">
            Путешествуйте выгоднее!
          </h2>
          <p class="text-gray-600 mb-6">
            Узнавайте первыми о выгодных ценах и спецпредложениях.
          </p>
          
          <form class="flex flex-col sm:flex-row gap-3">
            <input type="email" 
                   placeholder="example@mail.ru" 
                   class="flex-1 px-5 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
            <button type="submit" 
                    class="bg-primary text-white px-8 py-3 rounded-lg font-semibold hover:bg-blue-700 transition shadow-md">
              Подписаться
            </button>
          </form>
          
          <label class="flex items-center mt-4 text-sm text-gray-600">
            <input type="checkbox" class="mr-2 rounded border-gray-300 text-primary focus:ring-primary">
            Я согласен получать рассылки с новостями, рекламой и спецпредложениями
          </label>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Фото блок -->
<section class="py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <%= image_tag "hotelsbrands.png", alt: "Hotel Brands", class: "w-full h-auto" %>
  </div>
</section>

<!-- Блок преимущества -->
<section class="py-16 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

      <div class="bg-white p-8 rounded-xl shadow-md hover:shadow-xl transition">
        <div class="w-14 h-14 bg-green-100 rounded-full flex items-center justify-center mb-6">
          <i class="fas fa-ruble-sign text-2xl text-secondary"></i>
        </div>
        <h3 class="text-xl font-bold text-gray-800 mb-3">
          Низкие цены
        </h3>
        <p class="text-gray-600 leading-relaxed">
          Мы работаем напрямую с тысячами отелей, десятками поставщиков и можем контролировать цены на номера. Поэтому у нас всегда есть выгодные предложения на большинство направлений.
        </p>
      </div>
      
      <div class="bg-white p-8 rounded-xl shadow-md hover:shadow-xl transition">
        <div class="w-14 h-14 bg-blue-100 rounded-full flex items-center justify-center mb-6">
          <i class="fas fa-globe text-2xl text-primary"></i>
        </div>
        <h3 class="text-xl font-bold text-gray-800 mb-3">
          Отели по всему миру
        </h3>
        <p class="text-gray-600 leading-relaxed">
          У нас более 2700000 вариантов размещения по всему миру. Это отели, хостелы, апартаменты, виллы и даже кемпинги. В любой сезон вы найдёте то, что подходит именно вам.
        </p>
      </div>
      
      <div class="bg-white p-8 rounded-xl shadow-md hover:shadow-xl transition">
        <div class="w-14 h-14 bg-cyan-100 rounded-full flex items-center justify-center mb-6">
          <i class="fas fa-headset text-2xl text-accent"></i>
        </div>
        <h3 class="text-xl font-bold text-gray-800 mb-3">
          Заботливая поддержка 24/7
        </h3>
        <p class="text-gray-600 leading-relaxed">
          Операторы поддержки помогут с выбором отеля и бронированием. Если вопрос возник в поездке, оператор будет на связи и найдёт решение в кратчайший срок.
        </p>
      </div>
    </div>
  </div>
</section>

