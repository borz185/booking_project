<!-- Шапка -->
<header class="bg-white shadow-sm sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Логотип -->
      <div class="flex-shrink-0 flex items-center">
        <%= link_to root_path, class: "text-2xl font-bold text-primary" do %>
          <i class="fas fa-hotel mr-2"></i>booking.ru
        <% end %>
      </div>
      
      <!-- Меню -->
      <nav class="hidden md:flex space-x-8">
        <%= link_to hotels_path, class: "text-gray-700 hover:text-primary px-3 py-2 text-medium font-medium transition" do %>
          <i class="fas fa-bed mr-1"></i>Отели
        <% end %>
        <% if logged_in? %>
          <%= link_to bookings_path, class: "text-gray-700 hover:text-primary px-3 py-2 text-medium font-medium transition" do %>
            <i class="fas fa-calendar-check mr-1"></i>Бронирования
          <% end %>
        <% end %>
        <% if admin? %>
          <%= link_to admin_root_path, class: "text-purple-600 hover:text-purple-800 px-3 py-2 text-medium font-medium transition" do %>
            <i class="fas fa-shield-alt mr-1"></i>Админка
          <% end %>
        <% end %>
      </nav>
      
      <!-- Кнопки входа/профиль -->
      <div class="flex items-center space-x-4">
        <% if logged_in? %>
          <!-- Пользователь вошел -->
          <div class="relative inline-block group">
            <button class="flex items-center space-x-2 text-gray-700 hover:text-primary font-medium transition">
              <i class="fas fa-user-circle text-xl"></i>
              <span class="hidden md:inline"><%= current_user.username %></span>
              <i class="fas fa-chevron-down text-xs"></i>
            </button>
            
            <div class="absolute right-0 pt-2 invisible opacity-0 transition-all duration-200 ease-in-out group-hover:visible group-hover:opacity-100 hover:visible hover:opacity-100">
              <!-- Выпадающее меню -->
              <div class="w-48 bg-white rounded-lg shadow-lg py-2">
                <%= link_to bookings_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" do %>
                  <i class="fas fa-calendar-check mr-2"></i>Мои бронирования
                <% end %>
                <%= link_to profile_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" do %>
                  <i class="fas fa-user-circle mr-2"></i>Личный кабинет
                <% end %>
                <% if admin? %>
                  <div class="border-t border-gray-200 my-1"></div>
                  <span class="block px-4 py-2 text-sm text-gray-500">
                    <i class="fas fa-shield-alt mr-2"></i>Админ: <%= current_user.role %>
                  </span>
                <% end %>
                <div class="border-t border-gray-200 my-1"></div>
                <%= button_to logout_path, method: :delete, class: "block w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-gray-100", form: { class: "w-full" } do %>
                  <i class="fas fa-sign-out-alt mr-2"></i>Выйти
                <% end %>
              </div>
            </div>
          </div>
        <% else %>
          <!-- Пользователь не вошел -->
          <%= link_to login_path, class: "text-gray-700 hover:text-primary font-medium transition" do %>
            Войти
          <% end %>
          <%= link_to signup_path, class: "bg-primary text-white px-5 py-2 rounded-lg font-medium hover:bg-blue-700 transition shadow-md" do %>
            Регистрация
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</header>

<!-- Основной блок -->
<section class="bg-gradient-to-br from-green-400 via-green-300 to-cyan-300 py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-8">
      <h1 class="text-5xl md:text-6xl font-extrabold text-primary mb-4">
        Ооооочень много отелей!
      </h1>
    </div>
    
    <div class="flex flex-col md:flex-row items-center justify-between gap-8">
      <div class="flex-1">
        <p class="text-3xl md:text-4xl font-bold text-primary mb-8">
          Забронировать отпуск поможет booking!
        </p>
        <p class="text-lg md:text-xl text-gray-700 mb-8 max-w-2xl leading-relaxed">
          Более 2 700 000 отелей по всему миру. Лучшие цены, мгновенное подтверждение 
          и круглосуточная поддержка. Найдите идеальный отель за несколько минут!
        </p>
        <%= link_to hotels_path, class: "bg-primary text-white text-xl font-bold px-10 py-4 rounded-full hover:bg-blue-700 transition shadow-xl transform hover:scale-105 inline-flex items-center" do %>
          <i class="fas fa-search mr-2"></i>ОТЕЛИ
        <% end %>
      </div>
      
      <div class="flex-1 flex justify-center">
        <%= image_tag "photo-main.jpg", 
            alt: "Hotel", 
            class: "rounded-2xl shadow-2xl transform rotate-3 hover:rotate-0 transition duration-300" %>
      </div>
    </div>
  </div>
</section>

<!-- Блок подписки -->
<section class="bg-gray-100 py-16">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
      <div class="flex flex-col md:flex-row">
        <div class="md:w-1/3">
          <%= image_tag "photo-mail.jpg", alt: "Island", class: "w-full h-full object-cover" %>
        </div>
        <div class="md:w-2/3 p-8 md:p-12">
          <h2 class="text-3xl font-bold text-gray-800 mb-3">
            Путешествуйте выгоднее!
          </h2>
          <p class="text-gray-600 mb-6">
            Узнавайте первыми о выгодных ценах и спецпредложениях.
          </p>
          
          <!-- Сообщения об успехе/ошибке -->
          <% if flash[:notice] %>
            <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
              <i class="fas fa-check-circle mr-1"></i>
              <%= flash[:notice] %>
            </div>
          <% elsif flash[:alert] %>
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
              <i class="fas fa-exclamation-circle mr-1"></i>
              <%= flash[:alert] %>
            </div>
          <% end %>

          <!-- Форма подписки -->
          <%= form_with url: subscribe_path, method: :post, local: true, id: "subscribe-form", class: "space-y-4" do |f| %>
            <div class="flex flex-col sm:flex-row gap-3">
              <%= f.email_field :email, 
                  id: "subscribe-email",
                  required: true,
                  pattern: "[a-z0-9._%+\-]+@[a-z0-9.\-]+\.[a-z]{2,}$",
                  title: "Введите корректный email (например: example@mail.com)",
                  placeholder: "example@mail.com", 
                  class: "flex-1 px-5 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent",
                  autocomplete: "email" %>
              
              <%= f.submit "Подписаться", 
                  id: "subscribe-btn",
                  disabled: true,
                  class: "bg-gray-400 text-white px-8 py-3 rounded-lg font-semibold transition shadow-md cursor-not-allowed" %>
            </div>
            
            <!-- Чекбокс согласия (внутри формы!) -->
            <label class="flex items-start text-sm text-gray-600 cursor-pointer select-none">
              <%= check_box_tag :agreement, '1', false, 
                  id: "subscribe-agreement",
                  class: "mr-2 mt-1 rounded border-gray-300 text-primary focus:ring-primary" %>
              <span>Я согласен получать рассылки с новостями, рекламой и спецпредложениями</span>
            </label>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>

