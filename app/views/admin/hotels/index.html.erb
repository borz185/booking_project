<div class="bg-white rounded-lg shadow p-6">
<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Управление отелями</h1>
      <%= link_to admin_root_path, class: "inline-flex items-center px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition" do %>
        <i class="fas fa-arrow-left mr-2"></i>
        Назад к панели управления
      <% end %>
</div>

<div class="flex justify-between items-center mb-6">
  <div class="flex space-x-3">
    <!-- Поиск -->
    <%= form_with url: admin_hotels_path, method: :get, local: true, class: "flex space-x-2" do %>
      <div class="relative">
        <input type="text" 
               name="search" 
               value="<%= params[:search] %>" 
               placeholder="Поиск по названию, городу..."
               class="pl-10 pr-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary focus:border-primary w-64">
        <i class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
      </div>
      <%= submit_tag "Найти", class: "bg-primary text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition" %>
      <% if params[:search].present? %>
        <%= link_to "Сбросить", admin_hotels_path, class: "px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium hover:bg-gray-50 transition" %>
      <% end %>
    <% end %>

    <%= link_to new_admin_hotel_path, 
        class: "bg-primary text-white px-4 py-2 rounded-lg font-medium hover:bg-blue-700 transition shadow-md" do %>
      <i class="fas fa-plus mr-2"></i>Новый отель
    <% end %>
  </div>
</div>

<div class="bg-white rounded-xl shadow-md overflow-hidden">
  <table class="w-full">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Фото</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Название</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Город</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Звёзды</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Номера</th>
        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Действия</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @hotels.each do |hotel| %>
        <tr class="hover:bg-gray-50">
          <td class="px-6 py-4">
            <% if hotel.main_photo.attached? %>
              <%= image_tag hotel.main_photo.variant(resize_to_fill: [80, 60]), class: "rounded-lg" %>
            <% else %>
              <div class="w-20 h-15 bg-gray-200 rounded-lg flex items-center justify-center">
                <i class="fas fa-image text-gray-400"></i>
              </div>
            <% end %>
          </td>
          <td class="px-6 py-4 font-medium text-gray-900"><%= hotel.name %></td>
          <td class="px-6 py-4 text-gray-600"><%= hotel.city %>, <%= hotel.country %></td>
          <td class="px-6 py-4">
            <% hotel.stars.times do %><i class="fas fa-star text-yellow-400 text-sm"></i><% end %>
          </td>
          <td class="px-6 py-4 text-gray-600"><%= hotel.rooms.count %></td>
          <td class="px-6 py-4 text-right space-x-2">
            <%= link_to "Номера", admin_hotel_rooms_path(hotel), class: "text-primary hover:underline text-sm" %>
            <%= link_to "Ред.", edit_admin_hotel_path(hotel), class: "text-blue-600 hover:underline text-sm" %>
            <%= button_to "Удал.", admin_hotel_path(hotel), method: :delete, 
                data: { confirm: "Удалить отель #{hotel.name}?" }, 
                class: "text-red-600 hover:underline text-sm" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

<!-- Пагинация -->
<div class="mt-6 flex justify-center">
  <%= paginate @hotels %>
</div>
</div>
</div>