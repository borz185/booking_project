<%= form_with model: [:admin, hotel], local: true, class: "space-y-6" do |f| %>
  <!-- Название -->
  <div>
    <%= f.label :name, "Название отеля *", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name, required: true, maxlength: 150,
        class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" %>
    <% if hotel.errors[:name].any? %>
      <p class="mt-1 text-sm text-red-600"><%= hotel.errors[:name].first %></p>
    <% end %>
  </div>
  
  <!-- Город и страна -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= f.label :city, "Город *", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :city, required: true,
          class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" %>
    </div>
    <div>
      <%= f.label :country, "Страна *", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :country, required: true,
          class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" %>
    </div>
  </div>
  
  <!-- Адрес -->
  <div>
    <%= f.label :address, "Адрес *", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :address, required: true,
        class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" %>
  </div>
  
  <!-- Звёзды и телефон -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= f.label :stars, "Звёзды", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :stars, min: 1, max: 5,
          class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" %>
    </div>
    <div>
      <%= f.label :phone, "Телефон", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.telephone_field :phone, 
          placeholder: "+7 (999) 123-45-67",
          class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" %>
      <p class="mt-1 text-xs text-gray-500">
        <i class="fas fa-info-circle mr-1"></i>
        Только цифры, +, скобки и дефисы
      </p>
      <% if hotel.errors[:phone].any? %>
        <p class="mt-1 text-sm text-red-600">
          <i class="fas fa-times-circle mr-1"></i>
          <%= hotel.errors[:phone].first %>
        </p>
      <% end %>
    </div>
    <div>
      <%= f.label :commission_rate, "Комиссия (%)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :commission_rate, 
          min: 0, max: 100, step: 0.01,
          placeholder: "15.00",
          class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" %>
      <p class="mt-1 text-xs text-gray-500">
        <i class="fas fa-percent mr-1"></i>
        Процент от каждой брони, который пойдет в кассу
      </p>
      <% if hotel.errors[:commission_rate].any? %>
        <p class="mt-1 text-sm text-red-600">
          <i class="fas fa-times-circle mr-1"></i>
          <%= hotel.errors[:commission_rate].first %>
        </p>
      <% end %>
    </div>
  </div>
  
  <!-- Описание -->
  <div>
    <%= f.label :description, "Описание", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :description, rows: 4,
        class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" %>
  </div>
  
  <!-- Требуется виза -->
  <div class="flex items-center">
    <%= f.check_box :visa_required, class: "h-4 w-4 text-primary focus:ring-primary border-gray-300 rounded" %>
    <%= f.label :visa_required, "Требуется виза", class: "ml-2 text-sm text-gray-700" %>
  </div>
  
  <!-- Главное фото -->
  <div>
    <%= f.label :main_photo, "Главное фото отеля", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <% if hotel.main_photo.attached? %>
      <div class="mb-3">
        <%= image_tag hotel.main_photo.variant(resize_to_limit: [200, 150]), class: "rounded-lg shadow" %>
      </div>
    <% end %>
    <%= f.file_field :main_photo, accept: "image/*",
        class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" %>
    <p class="mt-1 text-xs text-gray-500">Рекомендуемый размер: 1200×800 px</p>
  </div>
  
  <!-- Кнопки -->
  <div class="flex space-x-3 pt-4">
    <%= f.submit hotel.new_record? ? "Создать отель" : "Сохранить изменения",
        class: "bg-primary text-white px-6 py-2 rounded-lg font-medium hover:bg-blue-700 transition" %>
    <%= link_to "Отмена", admin_hotels_path, class: "px-6 py-2 border border-gray-300 rounded-lg font-medium hover:bg-gray-50 transition" %>
  </div>
<% end %>