<div class="bg-white rounded-lg shadow p-6">
<h1 class="text-3xl font-bold text-gray-900 mb-6">Информация о пользователе</h1>

<div class="mb-4">
  <%= link_to admin_users_path, class: "inline-flex items-center text-primary hover:underline" do %>
    <i class="fas fa-arrow-left mr-2"></i>Вернуться к пользователям
  <% end %>
</div>

<!-- Карточка пользователя -->
<div class="bg-white rounded-xl shadow-md p-6 mb-8">
  <div class="flex items-center mb-6">
    <div class="h-20 w-20 rounded-full bg-gradient-to-br from-blue-400 to-cyan-400 flex items-center justify-center text-white text-3xl font-bold">
      <%= @user.username.first.upcase %>
    </div>
    <div class="ml-6">
      <h1 class="text-2xl font-bold text-gray-900"><%= @user.username %></h1>
      <p class="text-gray-600"><%= @user.email %></p>
    </div>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
    <div class="bg-gray-50 rounded-lg p-4">
      <p class="text-sm text-gray-500 mb-1">Телефон</p>
      <p class="font-medium"><%= @user.phone.presence || 'Не указан' %></p>
    </div>
    
    <div class="bg-gray-50 rounded-lg p-4">
      <p class="text-sm text-gray-500 mb-1">Роль</p>
      <p class="font-medium">
        <span class="px-2 py-1 rounded-full text-xs font-medium
          <%= @user.role_admin? ? 'bg-purple-100 text-purple-800' : 'bg-gray-100 text-gray-800' %>">
          <%= @user.role == 'admin' ? 'Администратор' : 'Пользователь' %>
        </span>
      </p>
    </div>
    
    <div class="bg-gray-50 rounded-lg p-4">
      <p class="text-sm text-gray-500 mb-1">Виза</p>
      <p class="font-medium">
        <% if @user.has_visa %>
          <span class="inline-flex items-center px-2 py-1 rounded-full bg-green-100 text-green-800 text-xs font-medium">
            <i class="fas fa-check mr-1"></i>Есть
          </span>
        <% else %>
          <span class="inline-flex items-center px-2 py-1 rounded-full bg-gray-100 text-gray-800 text-xs font-medium">
            <i class="fas fa-times mr-1"></i>Нет
          </span>
        <% end %>
      </p>
    </div>
    
    <div class="bg-gray-50 rounded-lg p-4">
      <p class="text-sm text-gray-500 mb-1">Дата регистрации</p>
      <p class="font-medium"><%= l @user.created_at, format: :long %></p>
    </div>
  </div>
  
  <div class="mt-4 bg-gray-50 rounded-lg p-4">
    <p class="text-sm text-gray-500 mb-1">Всего бронирований</p>
    <p class="text-2xl font-bold text-primary"><%= @bookings.count %></p>
  </div>
</div>

<!-- Бронирования пользователя -->
<div class="bg-white rounded-xl shadow-md p-6">
  <h2 class="text-xl font-bold text-gray-900 mb-4">Все бронирования</h2>
  
  <% if @bookings.any? %>
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">ID</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Отель / Номер</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Даты</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Гостей</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Статус</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Сумма</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Дата бронирования</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Действия</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @bookings.each do |booking| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 text-sm text-gray-500"><%= booking.booking_id %></td>
              <td class="px-6 py-4 text-sm">
                <div class="font-medium text-gray-900"><%= booking.room.hotel.name %></div>
                <div class="text-gray-500"><%= booking.room.room_number %> (<%= booking.room.room_type %>)</div>
              </td>
              <td class="px-6 py-4 text-sm">
                <div><%= l booking.check_in_date, format: :short %></div>
                <div class="text-gray-500"><%= l booking.check_out_date, format: :short %></div>
              </td>
              <td class="px-6 py-4 text-sm"><%= booking.guests_count %></td>
              <td class="px-6 py-4">
                <%= form_with model: [:admin, booking], method: :patch, local: true do |f| %>
                  <%= f.select :status, 
                      Booking.statuses.keys.map { |k| [k.humanize, k] },
                      { selected: booking.status },
                      class: "text-xs border border-gray-300 rounded px-2 py-1",
                      onchange: "this.form.submit()" %>
                <% end %>
              </td>
              <td class="px-6 py-4 text-sm font-medium"><%= number_to_currency(booking.total_price, unit: "₽", precision: 0) %></td>
              <td class="px-6 py-4 text-sm text-gray-500"><%= l booking.created_at, format: :short %></td>
              <td class="px-6 py-4 text-right">
                <%= button_to "Удалить", admin_booking_path(booking), 
                    method: :delete,
                    data: { confirm: "Удалить бронирование ##{booking.booking_id}?" },
                    class: "text-red-600 hover:underline text-sm" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="text-center py-12">
      <i class="fas fa-calendar-times text-6xl text-gray-300 mb-4"></i>
      <p class="text-gray-500 text-lg">У пользователя пока нет бронирований</p>
    </div>
  <% end %>
</div>
</div>