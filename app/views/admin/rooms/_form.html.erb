<%= form_with model: [:admin, @hotel, room], local: true, class: "space-y-6", multipart: true do |f| %>
  <!-- Номер комнаты и тип -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= f.label :room_number, "Номер комнаты *", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :room_number, required: true,
          class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" %>
    </div>
    <div>
      <%= f.label :room_type, "Тип номера *", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :room_type, required: true,
          class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" %>
    </div>
  </div>
  
  <!-- Вместимость и цена -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= f.label :capacity, "Вместимость (гостей) *", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :capacity, required: true, min: 1, max: 20,
          class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" %>
    </div>
    <div>
      <%= f.label :price_per_night, "Цена за ночь (₽) *", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :price_per_night, required: true, min: 0, step: 0.01,
          class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" %>
    </div>
  </div>
  
  <!-- Описание -->
  <div>
    <%= f.label :description, "Описание", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :description, rows: 3,
        class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" %>
  </div>
  
  <!-- Удобства -->
  <div>
    <%= f.label :amenities, "Удобства (через запятую)", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :amenities_input, 
        value: room.amenities.present? ? room.amenities.join(', ') : '',
        class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary",
        placeholder: "wifi, tv, ac, minibar, safe" %>
    <p class="mt-1 text-xs text-gray-500">Пример: wifi, tv, ac, minibar</p>
  </div>
  
  <!-- Доступность -->
  <div class="flex items-center">
    <%= f.check_box :is_available, class: "h-4 w-4 text-primary focus:ring-primary border-gray-300 rounded" %>
    <%= f.label :is_available, "Номер доступен для бронирования", class: "ml-2 text-sm text-gray-700" %>
  </div>
  
  <!-- Фотографии номера -->
  <div>
    <%= f.label :photos, "Фотографии номера (максимум 3)", class: "block text-sm font-medium text-gray-700 mb-1" %>
    
    <% if room.photos.attached? %>
      <div class="grid grid-cols-3 gap-3 mb-3">
        <% room.photos.each_with_index do |photo, index| %>
          <div class="relative">
            <%= image_tag photo.variant(resize_to_fill: [300, 200]), class: "rounded-lg shadow w-full h-40 object-cover" %>
            <div class="absolute top-2 left-2 bg-gray-800 bg-opacity-75 text-white text-xs px-2 py-1 rounded">
              Фото <%= index + 1 %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
    
    <%= f.file_field :photos, multiple: true, accept: "image/*",
        class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" %>
    <p class="mt-1 text-xs text-gray-500">Можно выбрать несколько файлов. Максимум 3 фото (JPG, PNG)</p>
  </div>
  
  <!-- Кнопки -->
  <div class="flex space-x-3 pt-4">
    <%= f.submit room.new_record? ? "Создать номер" : "Сохранить изменения",
        class: "bg-primary text-white px-6 py-2 rounded-lg font-medium hover:bg-blue-700 transition" %>
    <%= link_to "Отмена", admin_hotel_rooms_path(@hotel), class: "px-6 py-2 border border-gray-300 rounded-lg font-medium hover:bg-gray-50 transition" %>
  </div>
<% end %>