<div class="bg-white rounded-lg shadow p-6">
<div class="flex justify-between items-center mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Номера отеля</h1>
    <p class="text-gray-600 mt-1"><%= @hotel.name %></p>
  </div>
</div>

<div class="mb-4">
  <%= link_to admin_hotels_path, class: "inline-flex items-center text-primary hover:underline" do %>
    <i class="fas fa-arrow-left mr-2"></i>Вернуться к отелям
  <% end %>
</div>

<div class="flex justify-between items-center mb-6">
  <div class="flex space-x-3">
    <!-- Поиск -->
    <%= form_with url: admin_hotel_rooms_path(@hotel), method: :get, local: true, class: "flex space-x-2" do %>
      <div class="relative">
        <input type="text" 
               name="search" 
               value="<%= params[:search] %>" 
               placeholder="Поиск по номеру, типу..."
               class="pl-10 pr-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary focus:border-primary w-64">
        <i class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
      </div>
      <%= submit_tag "Найти", class: "bg-primary text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition" %>
      <% if params[:search].present? %>
        <%= link_to "Сбросить", admin_hotel_rooms_path(@hotel), class: "px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium hover:bg-gray-50 transition" %>
      <% end %>
    <% end %>
    
    <%= link_to new_admin_hotel_room_path(@hotel), 
        class: "bg-primary text-white px-4 py-2 rounded-lg font-medium hover:bg-blue-700 transition shadow-md" do %>
      <i class="fas fa-plus mr-2"></i>Новый номер
    <% end %>
  </div>
</div>

<!-- Информация об отеле -->
<div class="bg-white rounded-xl shadow-md p-6 mb-6">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-sm">
    <div>
      <span class="text-gray-500">Город:</span>
      <span class="ml-2 font-medium"><%= @hotel.city %></span>
    </div>
    <div>
      <span class="text-gray-500">Звёзды:</span>
      <span class="ml-2 font-medium">
        <% @hotel.stars.times do %><i class="fas fa-star text-yellow-400"></i><% end %>
      </span>
    </div>
    <div>
      <span class="text-gray-500">Всего номеров:</span>
      <span class="ml-2 font-medium"><%= @rooms.total_count %></span>
    </div>
  </div>
</div>

<!-- Список номеров -->
<div class="bg-white rounded-xl shadow-md overflow-hidden">
  <table class="w-full">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Номер</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Тип</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Вместимость</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Цена</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Фото</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Статус</th>
        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Действия</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @rooms.each do |room| %>
        <tr class="hover:bg-gray-50">
          <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= room.room_number %></td>
          <td class="px-6 py-4 text-sm text-gray-600"><%= room.room_type %></td>
          <td class="px-6 py-4 text-sm text-gray-600">
            <i class="fas fa-users mr-1"></i><%= room.capacity %>
          </td>
          <td class="px-6 py-4 text-sm font-medium text-gray-900">
            <%= number_to_currency(room.price_per_night, unit: "₽", precision: 0) %>
          </td>
          <td class="px-6 py-4 text-sm">
            <% if room.photos.attached? %>
              <span class="inline-flex items-center px-2 py-1 rounded-full bg-green-100 text-green-800 text-xs font-medium">
                <i class="fas fa-images mr-1"></i><%= room.photos.count %>
              </span>
            <% else %>
              <span class="inline-flex items-center px-2 py-1 rounded-full bg-gray-100 text-gray-800 text-xs font-medium">
                <i class="fas fa-times mr-1"></i>Нет
              </span>
            <% end %>
          </td>
          <td class="px-6 py-4 text-sm">
            <% if room.is_available %>
              <span class="inline-flex items-center px-2 py-1 rounded-full bg-green-100 text-green-800 text-xs font-medium">
                <i class="fas fa-check mr-1"></i>Доступен
              </span>
            <% else %>
              <span class="inline-flex items-center px-2 py-1 rounded-full bg-red-100 text-red-800 text-xs font-medium">
                <i class="fas fa-times mr-1"></i>Недоступен
              </span>
            <% end %>
          </td>
          <td class="px-6 py-4 text-right space-x-2">
            <%= link_to "Ред.", edit_admin_hotel_room_path(@hotel, room), 
                class: "text-indigo-600 hover:underline text-sm" %>
            <%= button_to "Удал.", admin_hotel_room_path(@hotel, room), method: :delete, 
                data: { confirm: "Удалить номер #{room.room_number}?" }, 
                class: "text-red-600 hover:underline text-sm" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<!-- Пагинация -->
<div class="mt-6 flex justify-center">
  <%= paginate @rooms if defined?(paginate) %>
</div>
</div>