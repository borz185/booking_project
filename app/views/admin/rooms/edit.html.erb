<div class="bg-white rounded-lg shadow p-6">
<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Редактировать номер</h1>
  <p class="text-gray-600 mt-1"><%= @hotel.name %> - <%= @room.room_number %> (<%= @room.room_type %>)</p>
</div>

<div class="mb-4">
  <%= link_to admin_hotel_rooms_path(@hotel), class: "inline-flex items-center text-primary hover:underline" do %>
    <i class="fas fa-arrow-left mr-2"></i>Вернуться к номерам
  <% end %>
</div>

<div class="bg-white rounded-xl shadow-md p-6">
  <%= render "form", room: @room %>
</div>
</div>