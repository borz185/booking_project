<div class="bg-white rounded-lg shadow p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Управление бронированиями</h1>
      <%= link_to admin_root_path, class: "inline-flex items-center px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition" do %>
        <i class="fas fa-arrow-left mr-2"></i>
        Назад к панели управления
      <% end %>
  </div>

  <!-- Фильтры по статусам -->
  <div class="flex space-x-3 mb-6">
    <%= link_to "Все", admin_bookings_path, 
        class: "px-4 py-2 rounded-lg text-sm font-medium transition #{params[:status].blank? ? 'bg-primary text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}" %>
    <%= link_to "Ожидает", admin_bookings_path(status: 'pending'), 
        class: "px-4 py-2 rounded-lg text-sm font-medium transition #{params[:status] == 'pending' ? 'bg-yellow-500 text-white' : 'bg-yellow-100 text-yellow-800 hover:bg-yellow-200'}" %>
    <%= link_to "Подтверждено", admin_bookings_path(status: 'confirmed'), 
        class: "px-4 py-2 rounded-lg text-sm font-medium transition #{params[:status] == 'confirmed' ? 'bg-green-500 text-white' : 'bg-green-100 text-green-800 hover:bg-green-200'}" %>
    <%= link_to "Завершено", admin_bookings_path(status: 'completed'), 
        class: "px-4 py-2 rounded-lg text-sm font-medium transition #{params[:status] == 'completed' ? 'bg-blue-500 text-white' : 'bg-blue-100 text-blue-800 hover:bg-blue-200'}" %>
    <%= link_to "Отменено", admin_bookings_path(status: 'cancelled'), 
        class: "px-4 py-2 rounded-lg text-sm font-medium transition #{params[:status] == 'cancelled' ? 'bg-red-500 text-white' : 'bg-red-100 text-red-800 hover:bg-red-200'}" %>
  </div>

  <!-- Поиск -->
  <div class="mb-6">
    <%= form_with url: admin_bookings_path, method: :get, local: true, class: "flex space-x-2" do %>
      <div class="relative flex-1">
        <input type="text"
               name="search"
               value="<%= params[:search] %>"
               placeholder="Поиск по ID, имени, отелю..."
               class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary focus:border-primary">
        <i class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
      </div>
      <%= submit_tag "Найти", class: "bg-primary text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition" %>
      <% if params[:search].present? %>
        <%= link_to "Сбросить", admin_bookings_path, class: "px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium hover:bg-gray-50 transition" %>
      <% end %>
    <% end %>
  </div>

  <!-- Таблица бронирований -->
  <div class="bg-white rounded-xl shadow-md overflow-hidden">
    <table class="w-full">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">ID</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Пользователь</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Отель / Номер</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Даты</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Сумма</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Комиссия</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Статус</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Действия</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @bookings.each do |booking| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 text-sm">#<%= booking.booking_id %></td>
            <td class="px-6 py-4 text-sm">
              <%= booking.user.username %><br>
              <span class="text-gray-500 text-xs"><%= booking.user.email %></span>
            </td>
            <td class="px-6 py-4 text-sm">
              <%= booking.room.hotel.name %><br>
              <span class="text-gray-500 text-xs"><%= booking.room.room_number %> (<%= booking.room.room_type %>)</span>
            </td>
            <td class="px-6 py-4 text-sm">
              <%= booking.check_in_date.strftime('%d.%m.%Y') %><br>
              <span class="text-gray-500 text-xs">— <%= booking.check_out_date.strftime('%d.%m.%Y') %></span>
            </td>
            <td class="px-6 py-4 text-sm font-medium">
              <%= number_to_currency(booking.total_price, unit: "₽", precision: 0) %>
            </td>
            <td class="px-6 py-4 text-sm">
              <% if booking.status == 'confirmed' || booking.status == 'completed' %>
                <span class="text-green-600 font-semibold">
                  +<%= number_to_currency(booking.calculate_commission, unit: "₽", precision: 2) %>
                </span>
                <span class="text-xs text-gray-500">
                  (<%= booking.room.hotel.commission_rate %>%)
                </span>
              <% else %>
                <span class="text-gray-400">—</span>
              <% end %>
            </td>
            <td class="px-6 py-4">
              <span class="px-3 py-1 inline-flex text-xs leading-5 font-semibold rounded-full <%= booking_status_badge_class(booking.status) %>">
                <%= booking_status_translation(booking.status) %>
              </span>
            </td>
            <td class="px-6 py-4 text-right">
              <%= form_with url: update_status_admin_booking_path(booking), method: :patch, local: true, class: "inline" do %>
                <select name="status" 
                        onchange="this.form.submit()"
                        class="text-xs border border-gray-300 rounded-lg px-3 py-1.5 focus:ring-2 focus:ring-primary focus:border-primary bg-white cursor-pointer hover:border-primary transition">
                  <option value="pending" <%= 'selected' if booking.status == 'pending' %>>
                    Ожидает
                  </option>
                  <option value="confirmed" <%= 'selected' if booking.status == 'confirmed' %>>
                    Подтверждено
                  </option>
                  <option value="completed" <%= 'selected' if booking.status == 'completed' %>>
                    Завершено
                  </option>
                  <option value="cancelled" <%= 'selected' if booking.status == 'cancelled' %>>
                    Отменено
                  </option>
                </select>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>