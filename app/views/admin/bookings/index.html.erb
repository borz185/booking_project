<div class="bg-white rounded-lg shadow p-6">
<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Управление бронированиями</h1>
</div>

<div class="mb-4">
  <%= link_to admin_root_path, class: "inline-flex items-center text-primary hover:underline" do %>
    <i class="fas fa-arrow-left mr-2"></i>Вернуться на панель управления
  <% end %>
</div>

<div class="flex justify-between items-center mb-6">
  <div class="flex space-x-3">
    <!-- Поиск -->
    <%= form_with url: admin_bookings_path, method: :get, local: true, class: "flex space-x-2" do %>
      <div class="relative">
        <input type="text" 
               name="search" 
               value="<%= params[:search] %>" 
               placeholder="Поиск по ID, имени, отелю..."
               class="pl-10 pr-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary focus:border-primary w-64">
        <i class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
      </div>
      <%= submit_tag "Найти", class: "bg-primary text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition" %>
      <% if params[:search].present? %>
        <%= link_to "Сбросить", admin_bookings_path, class: "px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium hover:bg-gray-50 transition" %>
      <% end %>
    <% end %>
  </div>
</div>

<div class="bg-white rounded-xl shadow-md overflow-hidden">
  <table class="w-full">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">ID</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Пользователь</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Отель / Номер</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Даты</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Статус</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Сумма</th>
        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Действия</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @bookings.each do |booking| %>
        <tr class="hover:bg-gray-50">
          <td class="px-6 py-4 text-sm"><%= booking.booking_id %></td>
          <td class="px-6 py-4 text-sm">
            <%= booking.user.username %><br>
            <span class="text-gray-500"><%= booking.user.email %></span>
          </td>
          <td class="px-6 py-4 text-sm">
            <%= booking.room.hotel.name %><br>
            <span class="text-gray-500"><%= booking.room.room_number %> (<%= booking.room.room_type %>)</span>
          </td>
          <td class="px-6 py-4 text-sm">
            <%= l booking.check_in_date, format: :short %><br>
            <span class="text-gray-500"><%= l booking.check_out_date, format: :short %></span>
          </td>
          <td class="px-6 py-4">
            <%= form_with model: [:admin, booking], method: :patch, local: true do |f| %>
              <%= f.select :status, 
                  Booking.statuses.keys.map { |k| [k.humanize, k] },
                  { selected: booking.status },
                  class: "text-xs border border-gray-300 rounded px-2 py-1",
                  onchange: "this.form.submit()" %>
            <% end %>
          </td>
          <td class="px-6 py-4 text-sm font-medium"><%= number_to_currency(booking.total_price, unit: "₽") %></td>
          <td class="px-6 py-4 text-right">
            <%= button_to "Удалить", admin_booking_path(booking), method: :delete,
                data: { confirm: "Удалить бронирование ##{booking.booking_id}?" },
                class: "text-red-600 hover:underline text-sm" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
</div>