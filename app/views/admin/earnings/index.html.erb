<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Заголовок -->
  <div class="mb-6">
    <div class="flex items-center justify-between">
      <h1 class="text-3xl font-bold text-gray-900">
        <i class="fas fa-chart-line mr-3 text-green-600"></i>
        Статистика заработка
      </h1>
      <%= link_to admin_root_path, class: "inline-flex items-center px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition" do %>
        <i class="fas fa-arrow-left mr-2"></i>
        Назад к панели управления
      <% end %>
    </div>
  </div>

  <!-- Карточки с метриками -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
    <div class="bg-gradient-to-br from-green-400 to-green-600 rounded-lg p-5 text-white shadow-lg">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm opacity-90 mb-1">Сегодня</p>
          <p class="text-3xl font-bold"><%= number_to_currency(@metrics[:today], unit: '₽', precision: 0) %></p>
        </div>
        <i class="fas fa-calendar-day text-4xl opacity-50"></i>
      </div>
    </div>
    
    <div class="bg-gradient-to-br from-blue-400 to-blue-600 rounded-lg p-5 text-white shadow-lg">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm opacity-90 mb-1">Этот месяц</p>
          <p class="text-3xl font-bold"><%= number_to_currency(@metrics[:this_month], unit: '₽', precision: 0) %></p>
        </div>
        <i class="fas fa-calendar-alt text-4xl opacity-50"></i>
      </div>
    </div>
    
    <div class="bg-gradient-to-br from-purple-400 to-purple-600 rounded-lg p-5 text-white shadow-lg">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm opacity-90 mb-1">Этот год</p>
          <p class="text-3xl font-bold"><%= number_to_currency(@metrics[:this_year], unit: '₽', precision: 0) %></p>
        </div>
        <i class="fas fa-calendar text-4xl opacity-50"></i>
      </div>
    </div>
    
    <div class="bg-gradient-to-br from-orange-400 to-orange-600 rounded-lg p-5 text-white shadow-lg">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm opacity-90 mb-1">Всего записей</p>
          <p class="text-3xl font-bold"><%= @metrics[:count] %></p>
        </div>
        <i class="fas fa-database text-4xl opacity-50"></i>
      </div>
    </div>
  </div>

  <!-- Фильтры и поиск -->
  <div class="bg-white rounded-xl shadow-md p-6 mb-6">
    <%= form_with url: admin_earnings_path, method: :get, local: true, class: "flex flex-col md:flex-row gap-4" do %>
      <!-- Фильтр по периоду -->
      <div class="flex-1">
        <label class="block text-sm font-medium text-gray-700 mb-2">
          <i class="fas fa-filter mr-1"></i>Период
        </label>
        <select name="period" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary">
          <option value="">Все время</option>
          <option value="today" <%= 'selected' if params[:period] == 'today' %>>Сегодня</option>
          <option value="month" <%= 'selected' if params[:period] == 'month' %>>Этот месяц</option>
          <option value="year" <%= 'selected' if params[:period] == 'year' %>>Этот год</option>
        </select>
      </div>
      
      <!-- Поиск по отелю -->
      <div class="flex-1">
        <label class="block text-sm font-medium text-gray-700 mb-2">
          <i class="fas fa-search mr-1"></i>Поиск по отелю
        </label>
        <input type="text" 
               name="hotel_search" 
               value="<%= params[:hotel_search] %>"
               placeholder="Название отеля..."
               class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary">
      </div>
      
      <!-- Кнопки -->
      <div class="flex items-end space-x-2">
        <%= submit_tag "Применить", class: "bg-primary text-white px-6 py-2 rounded-lg font-medium hover:bg-blue-700 transition cursor-pointer" %>
        <%= link_to "Сбросить", admin_earnings_path, class: "px-6 py-2 border border-gray-300 rounded-lg font-medium hover:bg-gray-50 transition" %>
      </div>
    <% end %>
  </div>

  <!-- Таблица всех записей -->
  <div class="bg-white rounded-xl shadow-md overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-xl font-bold text-gray-900">
        Все записи о заработке
        <% if @earnings.total_pages > 1 %>
          <span class="text-sm font-normal text-gray-500 ml-2">
            (Страница <%= @earnings.current_page %> из <%= @earnings.total_pages %>)
          </span>
        <% end %>
      </h2>
    </div>
    
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Дата и время
            </th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Отель
            </th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Бронирование
            </th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Ставка комиссии
            </th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
              Сумма дохода
            </th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% if @earnings.any? %>
            <% @earnings.each do |earning| %>
              <tr class="hover:bg-gray-50 transition">
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
                  <div class="flex items-center">
                    <i class="fas fa-clock text-gray-400 mr-2"></i>
                    <%= earning.earned_at.strftime('%d.%m.%Y %H:%M') %>
                  </div>
                </td>
                <td class="px-6 py-4 text-sm text-gray-900">
                  <div class="font-medium"><%= earning.hotel.name %></div>
                  <div class="text-gray-500 text-xs"><%= earning.hotel.city %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
                  <span class="bg-gray-100 text-gray-800 px-2 py-1 rounded text-xs">
                    #<%= earning.booking.booking_id %>
                  </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm">
                  <span class="bg-blue-100 text-blue-800 px-3 py-1 rounded-full text-xs font-semibold">
                    <%= earning.commission_rate %>%
                  </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right">
                  <span class="text-lg font-bold text-green-600">
                    +<%= number_to_currency(earning.amount, unit: '₽', precision: 2) %>
                  </span>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="5" class="px-6 py-12 text-center text-gray-500">
                <i class="fas fa-inbox text-4xl text-gray-300 mb-3"></i>
                <p>Нет записей о заработке за выбранный период</p>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    
    <!-- Пагинация -->
    <% if @earnings.total_pages > 1 %>
      <div class="px-6 py-4 border-t border-gray-200">
        <%= paginate @earnings %>
      </div>
    <% end %>
  </div>
</div>