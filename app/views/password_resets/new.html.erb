<div class="min-h-screen bg-gradient-to-br from-blue-50 via-white to-cyan-50 flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full">
    <!-- Логотип -->
    <div class="text-center mb-8">
      <a href="/" class="inline-block text-3xl font-bold text-primary">
        <i class="fas fa-hotel mr-2"></i>booking.ru
      </a>
    </div>

    <!-- Форма ввода email -->
    <div class="bg-white rounded-2xl shadow-xl p-8">
      <div class="text-center mb-6">
        <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <i class="fas fa-key text-2xl text-primary"></i>
        </div>
        <h2 class="text-2xl font-bold text-gray-800 mb-2">
          Восстановление пароля
        </h2>
        <p class="text-gray-600 text-sm">
          Шаг 1 из 3: Введите email аккаунта
        </p>
      </div>

      <% if flash[:alert] %>
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6 text-sm">
          <i class="fas fa-exclamation-circle mr-1"></i>
          <%= flash[:alert] %>
        </div>
      <% end %>

      <%= form_with url: send_reset_code_path, method: :post, local: true, class: "space-y-5" do |f| %>
        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-2" do %>
            <i class="fas fa-envelope mr-1 text-gray-400"></i>Email
          <% end %>
          <%= f.email_field :email,
              required: true,
              autofocus: true,
              autocomplete: "email",
              placeholder: "example@mail.ru",
              class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition" %>
        </div>

        <%= f.submit "Получить код",
            class: "w-full bg-primary text-white py-3 rounded-lg font-semibold hover:bg-blue-700 transition shadow-md cursor-pointer flex items-center justify-center" %>
      <% end %>

      <p class="mt-6 text-center text-sm text-gray-600">
        Вспомнили пароль?
        <%= link_to "Войти", login_path, class: "font-medium text-primary hover:text-blue-700" %>
      </p>
    </div>
  </div>
</div>