<div class="min-h-screen bg-gradient-to-br from-blue-50 via-white to-cyan-50 flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full">
    <!-- Логотип -->
    <div class="text-center mb-8">
      <a href="/" class="inline-block text-3xl font-bold text-primary">
        <i class="fas fa-hotel mr-2"></i>booking.ru
      </a>
    </div>

    <!-- Форма ввода кода -->
    <div class="bg-white rounded-2xl shadow-xl p-8">
      <div class="text-center mb-6">
        <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <i class="fas fa-envelope-open-text text-2xl text-green-600"></i>
        </div>
        <h2 class="text-2xl font-bold text-gray-800 mb-2">
          Введите код
        </h2>
        <p class="text-gray-600 text-sm">
          Шаг 2 из 3: Код отправлен на<br>
          <span class="font-medium text-primary"><%= session[:reset_email] %></span>
        </p>
        <p class="text-xs text-gray-500 mt-2">
          <i class="fas fa-clock mr-1"></i>Код действителен 10 минут
        </p>
      </div>

      <% if flash[:alert] %>
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6 text-sm">
          <i class="fas fa-exclamation-circle mr-1"></i>
          <%= flash[:alert] %>
        </div>
      <% end %>

      <% if flash[:notice] %>
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6 text-sm">
          <i class="fas fa-check-circle mr-1"></i>
          <%= flash[:notice] %>
        </div>
      <% end %>

      <%= form_with url: verify_reset_code_path, method: :post, local: true, class: "space-y-5" do |f| %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">
            <i class="fas fa-shield-alt mr-1 text-gray-400"></i>4-значный код
          </label>
          <input type="text"
                 name="code"
                 required
                 maxlength="4"
                 pattern="\d{4}"
                 autocomplete="one-time-code"
                 inputmode="numeric"
                 autofocus
                 class="w-full px-4 py-3 border-2 border-gray-200 rounded-lg text-center text-3xl font-mono font-bold tracking-widest focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition"
                 placeholder="0000">
          <p class="mt-2 text-xs text-gray-500 text-center">
            Введите 4 цифры из письма
          </p>
        </div>

        <%= f.submit "Подтвердить код",
            class: "w-full bg-primary text-white py-3 rounded-lg font-semibold hover:bg-blue-700 transition shadow-md cursor-pointer flex items-center justify-center" %>
      <% end %>

      <!-- Повторная отправка кода -->
      <div class="mt-6 text-center">
        <p class="text-sm text-gray-600 mb-2">Не получили код?</p>
        <%= form_with url: send_reset_code_path, method: :post, local: true do |f| %>
          <input type="hidden" name="email" value="<%= session[:reset_email] %>">
          <%= f.submit "Отправить код повторно",
              class: "text-primary hover:text-blue-700 font-medium text-sm cursor-pointer underline" %>
        <% end %>
      </div>

      <p class="mt-4 text-center text-sm text-gray-600">
        <%= link_to "← Вернуться к вводу email", forgot_password_path, class: "text-gray-500 hover:text-gray-700" %>
      </p>
    </div>
  </div>
</div>

<script>
  // Автофокус на следующее поле при вводе кода
  document.addEventListener('DOMContentLoaded', function() {
    const codeInput = document.querySelector('input[name="code"]');
    if (codeInput) {
      codeInput.addEventListener('input', function(e) {
        // Разрешаем только цифры
        this.value = this.value.replace(/\D/g, '');
      });
      
      codeInput.addEventListener('paste', function(e) {
        e.preventDefault();
        const pastedText = (e.clipboardData || window.clipboardData).getData('text');
        this.value = pastedText.replace(/\D/g, '').slice(0, 4);
      });
    }
  });
</script>