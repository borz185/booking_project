<div class="min-h-screen bg-gradient-to-br from-blue-50 via-white to-cyan-50 flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full">
    <!-- Логотип -->
    <div class="text-center mb-8">
      <a href="/" class="inline-block text-3xl font-bold text-primary">
        <i class="fas fa-hotel mr-2"></i>booking.ru
      </a>
    </div>

    <!-- Форма нового пароля -->
    <div class="bg-white rounded-2xl shadow-xl p-8">
      <div class="text-center mb-6">
        <div class="w-16 h-16 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <i class="fas fa-lock-open text-2xl text-purple-600"></i>
        </div>
        <h2 class="text-2xl font-bold text-gray-800 mb-2">
          Новый пароль
        </h2>
        <p class="text-gray-600 text-sm">
          Шаг 3 из 3: Установите новый пароль
        </p>
      </div>

      <% if flash[:alert] %>
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6 text-sm">
          <i class="fas fa-exclamation-circle mr-1"></i>
          <%= flash[:alert] %>
        </div>
      <% end %>

      <%= form_with url: update_reset_password_path, method: :post, local: true, class: "space-y-5" do |f| %>
        <!-- Новый пароль -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">
            <i class="fas fa-lock mr-1 text-gray-400"></i>Новый пароль
          </label>
          <input type="password"
                 name="password"
                 required
                 minlength="6"
                 autocomplete="new-password"
                 placeholder="Минимум 6 символов"
                 class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition"
                 id="password">
          <p class="mt-1 text-xs text-gray-500">Минимум 6 символов</p>
        </div>

        <!-- Подтверждение пароля -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">
            <i class="fas fa-lock mr-1 text-gray-400"></i>Подтвердите пароль
          </label>
          <input type="password"
                 name="password_confirmation"
                 required
                 minlength="6"
                 autocomplete="new-password"
                 placeholder="Повторите пароль"
                 class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition"
                 id="password_confirmation">
          <p class="mt-1 text-xs text-red-600 hidden" id="mismatch-error">
            <i class="fas fa-times-circle mr-1"></i>Пароли не совпадают
          </p>
        </div>

        <!-- Индикатор совпадения -->
        <div id="match-indicator" class="hidden text-sm font-medium">
          <i class="fas fa-check-circle text-green-500 mr-1"></i>
          <span class="text-green-600">Пароли совпадают</span>
        </div>

        <%= f.submit "Сменить пароль и войти",
            class: "w-full bg-primary text-white py-3 rounded-lg font-semibold hover:bg-blue-700 transition shadow-md cursor-pointer flex items-center justify-center",
            id: "submit-btn" %>
      <% end %>

      <p class="mt-6 text-center text-sm text-gray-600">
        <%= link_to "← Вернуться к вводу email", forgot_password_path, class: "text-gray-500 hover:text-gray-700" %>
      </p>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const password = document.getElementById('password');
    const confirmation = document.getElementById('password_confirmation');
    const mismatchError = document.getElementById('mismatch-error');
    const matchIndicator = document.getElementById('match-indicator');
    const submitBtn = document.getElementById('submit-btn');

    function checkMatch() {
      const pass = password.value;
      const conf = confirmation.value;

      if (conf.length === 0) {
        mismatchError.classList.add('hidden');
        matchIndicator.classList.add('hidden');
        submitBtn.disabled = false;
        return;
      }

      if (pass === conf && pass.length >= 6) {
        mismatchError.classList.add('hidden');
        matchIndicator.classList.remove('hidden');
        submitBtn.disabled = false;
      } else {
        mismatchError.classList.remove('hidden');
        matchIndicator.classList.add('hidden');
        submitBtn.disabled = false;
      }
    }

    password.addEventListener('input', checkMatch);
    confirmation.addEventListener('input', checkMatch);

    // Проверка перед отправкой
    submitBtn.addEventListener('click', function(e) {
      if (password.value !== confirmation.value) {
        e.preventDefault();
        mismatchError.classList.remove('hidden');
        return false;
      }
    });
  });
</script>