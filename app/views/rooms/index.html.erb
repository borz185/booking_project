<!-- JavaScript для модального окна и расчета стоимости -->
<script>
  // Глобальные переменные для модального окна
  let currentRoomId = null;
  let currentPricePerNight = 0;
  
  // Открытие модального окна
  function openBookingModal(roomId, roomType, pricePerNight, roomNumber) {
    currentRoomId = roomId;
    currentPricePerNight = pricePerNight;
    
    document.getElementById('modalRoomInfo').textContent = `${roomType}, номер ${roomNumber}`;
    document.getElementById('pricePerNight').textContent = `${new Intl.NumberFormat('ru-RU').format(pricePerNight)} ₽`;
    
    // Сбрасываем только редактируемые поля (даты и количество гостей)
    document.getElementById('checkIn').value = '';
    document.getElementById('checkOut').value = '';
    document.getElementById('guests').value = 2;
    
    // ФИО и телефон остаются readonly - их не трогаем
    
    const today = new Date().toISOString().split('T')[0];
    document.getElementById('checkIn').min = today;
    document.getElementById('checkOut').min = today;
    
    document.getElementById('bookingModal').classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }
  
  // Закрытие модального окна
  function closeBookingModal() {
    document.getElementById('bookingModal').classList.add('hidden');
    document.body.style.overflow = ''; // Восстанавливаем прокрутку
  }
  
  // Расчет общей стоимости
  function calculateTotal() {
    const checkIn = document.getElementById('checkIn').value;
    const checkOut = document.getElementById('checkOut').value;
    const guests = parseInt(document.getElementById('guests').value) || 1;
    
    if (checkIn && checkOut) {
      const startDate = new Date(checkIn);
      const endDate = new Date(checkOut);
      const nights = Math.ceil((endDate - startDate) / (1000 * 60 * 60 * 24));
      
      if (nights > 0) {
        const total = nights * currentPricePerNight;
        document.getElementById('nightsCount').textContent = nights;
        document.getElementById('totalPrice').textContent = 
          `${new Intl.NumberFormat('ru-RU').format(total)} ₽`;
        return;
      }
    }
    
    // Если даты не выбраны или некорректны
    document.getElementById('nightsCount').textContent = '0';
    document.getElementById('totalPrice').textContent = '0 ₽';
  }
  
  // Обработчик отправки формы бронирования
  document.getElementById('bookingForm')?.addEventListener('submit', function(e) {
    e.preventDefault();
    
    // Сбрасываем ошибки
    const guestNameInput = document.getElementById('guestName');
    const guestPhoneInput = document.getElementById('guestPhone');
    const guestNameError = document.getElementById('guestNameError');
    const guestPhoneError = document.getElementById('guestPhoneError');
    
    // Очищаем предыдущие ошибки
    if (guestNameError) guestNameError.classList.add('hidden');
    if (guestPhoneError) guestPhoneError.classList.add('hidden');
    guestNameInput.classList.remove('border-red-500');
    guestPhoneInput.classList.remove('border-red-500');
    
    let hasErrors = false;
    
    // Валидация ФИО
    const guestName = guestNameInput.value.trim();
    // Разбиваем на слова (убираем лишние пробелы)
    const nameWords = guestName.split(/\s+/).filter(word => word.length > 0);
    const namePattern = /^[a-zA-Zа-яА-Я0-9_\s]{3,100}$/;

    if (!guestName) {
      if (guestNameError) {
        guestNameError.textContent = 'ФИО обязательно для заполнения';
        guestNameError.classList.remove('hidden');
      }
      guestNameInput.classList.add('border-red-500');
      hasErrors = true;
    } else if (!namePattern.test(guestName)) {
      if (guestNameError) {
        guestNameError.textContent = 'ФИО может содержать только буквы и цифры';
        guestNameError.classList.remove('hidden');
      }
      guestNameInput.classList.add('border-red-500');
      hasErrors = true;
    } else if (nameWords.length < 2) {
      if (guestNameError) {
        guestNameError.textContent = 'Пожалуйста, введите фамилию и имя (минимум 2 слова)';
        guestNameError.classList.remove('hidden');
      }
      guestNameInput.classList.add('border-red-500');
      hasErrors = true;
    } else if (guestName.length < 5) {
      if (guestNameError) {
        guestNameError.textContent = 'ФИО должно содержать минимум 5 символов';
        guestNameError.classList.remove('hidden');
      }
      guestNameInput.classList.add('border-red-500');
      hasErrors = true;
    } else {
      // Проверяем длину каждого слова
      const hasShortWord = nameWords.some(word => word.length < 2);
      if (hasShortWord) {
        if (guestNameError) {
          guestNameError.textContent = 'Каждое слово должно содержать минимум 2 символа';
          guestNameError.classList.remove('hidden');
        }
        guestNameInput.classList.add('border-red-500');
        hasErrors = true;
      }
    }
    
    // Валидация телефона
    const guestPhone = guestPhoneInput.value.trim();
    const phonePattern = /^\+?[0-9\-\(\) ]{10,20}$/;
    
    if (!guestPhone) {
      if (guestPhoneError) {
        guestPhoneError.textContent = 'Телефон обязателен для заполнения';
        guestPhoneError.classList.remove('hidden');
      }
      guestPhoneInput.classList.add('border-red-500');
      hasErrors = true;
    } else if (!phonePattern.test(guestPhone)) {
      if (guestPhoneError) {
        guestPhoneError.textContent = 'Введите телефон в корректном формате (например: +7 (999) 999-99-99)';
        guestPhoneError.classList.remove('hidden');
      }
      guestPhoneInput.classList.add('border-red-500');
      hasErrors = true;
    }
    
    // Если есть ошибки, прекращаем выполнение
    if (hasErrors) {
      return;
    }
    
    // Валидация дат
    const checkIn = document.getElementById('checkIn').value;
    const checkOut = document.getElementById('checkOut').value;
    
    if (!checkIn || !checkOut) {
      alert('Пожалуйста, выберите даты заезда и выезда');
      return;
    }
    
    const startDate = new Date(checkIn);
    const endDate = new Date(checkOut);
    const nights = Math.ceil((endDate - startDate) / (1000 * 60 * 60 * 24));
    
    if (nights <= 0) {
      alert('Дата выезда должна быть позже даты заезда');
      return;
    }
    
    // Отправка данных на сервер
    const submitBtn = this.querySelector('button[type="submit"]');
    const originalText = submitBtn.innerHTML;
    
    // Состояние загрузки
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i>Бронируем...';
    
    // Формирование данных для отправки
    const formData = {
      room_id: currentRoomId,
      check_in_date: checkIn,
      check_out_date: checkOut,
      guests_count: document.getElementById('guests').value,
      guest_name: guestName,
      guest_phone: guestPhone
    };
    
    // Отправляем AJAX запрос
    fetch('/bookings', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
      },
      body: JSON.stringify(formData)
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        // Успешное бронирование
        const guests = formData.guests_count;
        let guestsText = 'гостей';
        if (guests == 1) guestsText = 'гость';
        else if (guests >= 2 && guests <= 4) guestsText = 'гостя';
        
        alert(`Бронирование успешно создано!\n\n` +
              `Номер: ${document.getElementById('modalRoomInfo').textContent}\n` +
              `Гость: ${guestName}\n` +
              `Даты: ${checkIn} — ${checkOut}\n` +
              `Гостей: ${guests} ${guestsText}\n` +
              `Сумма: ${document.getElementById('totalPrice').textContent}\n\n` +
              `Вы можете увидеть его в разделе "Мои бронирования".`);
        closeBookingModal();
      } else {
        // Ошибка при бронировании
        alert('Ошибка при бронировании:\n' + (data.errors ? data.errors.join('\n') : 'Не удалось забронировать'));
      }
    })
    .catch(error => {
      console.error('Error:', error);
      alert('Произошла ошибка сети. Попробуйте позже.');
    })
    .finally(() => {
      // Возвращаем кнопку в исходное состояние
      submitBtn.disabled = false;
      submitBtn.innerHTML = originalText;
    });
  });
  
  // Закрытие модального окна по клавише Escape
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      closeBookingModal();
    }
  });
  
  // Авто-расчет при изменении дат
  document.getElementById('checkIn')?.addEventListener('change', calculateTotal);
  document.getElementById('checkOut')?.addEventListener('change', calculateTotal);
</script>

<script>
// Карусель для фото номеров
document.addEventListener('DOMContentLoaded', function() {
  // Инициализация всех каруселей
  document.querySelectorAll('.carousel-container').forEach(container => {
    const roomId = container.dataset.roomId;
    initializeCarousel(roomId);
  });
});

function initializeCarousel(roomId) {
  const container = document.querySelector(`.carousel-container[data-room-id="${roomId}"]`);
  if (!container) return;
  
  const items = container.querySelectorAll('.carousel-item');
  const prevBtn = document.querySelector(`.carousel-prev[data-room-id="${roomId}"]`);
  const nextBtn = document.querySelector(`.carousel-next[data-room-id="${roomId}"]`);
  const indicators = document.querySelectorAll(`.carousel-indicator[data-room-id="${roomId}"]`);
  
  let currentIndex = 0;
  
  function showSlide(index) {
    // Скрываем все слайды
    items.forEach(item => item.classList.add('hidden'));
    // Показываем текущий
    items[index].classList.remove('hidden');
    
    // Обновляем индикаторы
    indicators.forEach((indicator, i) => {
      if (i === index) {
        indicator.classList.remove('opacity-50');
        indicator.classList.add('opacity-100');
      } else {
        indicator.classList.remove('opacity-100');
        indicator.classList.add('opacity-50');
      }
    });
    
    currentIndex = index;
  }
  
  function nextSlide() {
    const nextIndex = (currentIndex + 1) % items.length;
    showSlide(nextIndex);
  }
  
  function prevSlide() {
    const prevIndex = (currentIndex - 1 + items.length) % items.length;
    showSlide(prevIndex);
  }
  
  // Обработчики событий
  if (nextBtn) {
    nextBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      nextSlide();
    });
  }
  
  if (prevBtn) {
    prevBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      prevSlide();
    });
  }
  
  // Клик по индикаторам
  indicators.forEach((indicator, index) => {
    indicator.addEventListener('click', function(e) {
      e.stopPropagation();
      showSlide(index);
    });
  });
}
</script>